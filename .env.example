# mirth-ai-triage — environment variables (example)
# Copy this file to `.env` and fill in your own values.
# Never commit `.env`.

# --- Model providers ---
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: only needed if you wire in OpenAI as a fallback provider.
# OPENAI_API_KEY=your_openai_api_key_here

# --- Runtime flags ---
# DEMO_MODE=true keeps the prototype in synthetic-data-only mode.
# Do NOT set DEMO_MODE=false unless you know exactly what you are doing,
# and even then this prototype is not approved for real PHI.
DEMO_MODE=true

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path the demo reads its synthetic samples from.
SAMPLES_DIR=./samples

# --- Optional: model selection ---
# Anthropic model string. Leave default unless you have a reason to change.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Notes ---
# 1. This file should contain placeholders only.
# 2. The repo's safety scanner will fail the build if a real-looking
#    secret ever appears here.
# 3. See docs/SAFETY_MODEL.md for the full safety policy.
